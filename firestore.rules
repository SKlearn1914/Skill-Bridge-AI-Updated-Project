rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Primitives ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isVerified() {
      return isSignedIn() && (request.auth.token.email_verified == true);
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Helpers ---

    function isValidUser(data) {
      return data.uid == request.auth.uid
        && data.email is string
        && data.email.size() <= 256;
    }

    function isValidResume(data) {
      return data.userId == request.auth.uid
        && data.rawText is string
        && data.rawText.size() <= 100000;
    }

    function isValidReport(data) {
      return data.userId == request.auth.uid
        && data.resumeId is string
        && data.matchScore is number;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidUser(incoming());
    }

    match /resumes/{resumeId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidResume(incoming());
      allow update: if isSignedIn() && isOwner(existing().userId) && isValidResume(incoming()) && incoming().userId == existing().userId;
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }

    match /reports/{reportId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidReport(incoming());
      allow update: if isSignedIn() && isOwner(existing().userId) && isValidReport(incoming()) && incoming().userId == existing().userId;
      allow delete: if isSignedIn() && isOwner(existing().userId);
    }
  }
}
